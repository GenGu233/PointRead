<Window x:Class="PointRead.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PointRead"
        Width="560"
        Height="470"
        MinWidth="520"
        MinHeight="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>
    <Grid Background="#EEF2F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="20,18"
                Background="#FFFFFF"
                BorderBrush="#DDE4EE"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="44"
                        Height="44"
                        CornerRadius="10"
                        Background="#2563EB">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="P" />
                </Border>
                <StackPanel Grid.Column="1"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Text="PointRead" />
                    <TextBlock x:Name="HotkeyHintText"
                               Margin="0,4,0,0"
                               Foreground="#64748B"
                               Text="按 Alt + Q 进入点读模式" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="20"
                      VerticalScrollBarVisibility="Auto">
            <Border Padding="16"
                    Background="#FFFFFF"
                    BorderBrush="#D9E2EF"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Text="当前状态" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="已准备好。等待快捷键触发。" />
                    <TextBlock Margin="0,16,0,0"
                               FontWeight="SemiBold"
                               Text="识别结果" />
                    <TextBox x:Name="RecognizedTextBox"
                             Margin="0,8,0,0"
                             MinHeight="118"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                    <TextBlock Margin="0,16,0,0"
                               FontWeight="SemiBold"
                               Text="播放控制" />
                    <WrapPanel Margin="0,8,0,0">
                        <Button Width="78"
                                Margin="0,0,8,8"
                                Click="PreviousSentenceButton_Click"
                                Content="后退 5s" />
                        <Button Width="88"
                                Margin="0,0,8,8"
                                Click="PlayPauseButton_Click"
                                Content="暂停/继续" />
                        <Button Width="78"
                                Margin="0,0,8,8"
                                Click="NextSentenceButton_Click"
                                Content="前进 5s" />
                        <Button Width="68"
                                Margin="0,0,8,8"
                                Click="StopButton_Click"
                                Content="停止" />
                    </WrapPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center"
                                   Text="语速" />
                        <Slider x:Name="RateSlider"
                                Grid.Column="1"
                                Margin="12,0"
                                Minimum="-5"
                                Maximum="5"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                ValueChanged="RateSlider_ValueChanged" />
                        <TextBlock x:Name="RateValueText"
                                   Grid.Column="2"
                                   Width="42"
                                   VerticalAlignment="Center"
                                   Text="1.0x" />
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Margin="20,0,20,20"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="92"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="SettingsButton_Click"
                    Content="设置" />
            <Button Width="92"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="StartSelectionButton_Click"
                    Content="开始框选" />
            <Button Width="92"
                    Height="32"
                    Click="ExitButton_Click"
                    Content="退出" />
        </StackPanel>
    </Grid>
</Window>
