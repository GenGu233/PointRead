<Window x:Class="PointRead.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="420"
        Height="460"
        MinWidth="420"
        MinHeight="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="20"
                   FontWeight="SemiBold"
                   Text="设置" />

        <ScrollViewer Grid.Row="1"
                      Margin="0,18,0,12"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="框读" />
                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="Alt +" />
                        <ComboBox x:Name="HotkeyComboBox"
                                  Width="80"
                                  Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="默认语速" />
                    <Slider x:Name="RateSlider"
                            Grid.Column="1"
                            Margin="16,0"
                            Minimum="-5"
                            Maximum="5"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            ValueChanged="RateSlider_ValueChanged" />
                    <TextBlock x:Name="RateValueText"
                               Grid.Column="2"
                               Width="42"
                               VerticalAlignment="Center"
                               Text="1.0x" />
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="截图缩放校准" />
                    <Slider x:Name="CaptureScaleSlider"
                            Grid.Column="1"
                            Margin="16,0"
                            Minimum="0.9"
                            Maximum="1.1"
                            TickFrequency="0.01"
                            IsSnapToTickEnabled="True"
                            ValueChanged="CaptureScaleSlider_ValueChanged" />
                    <TextBlock x:Name="CaptureScaleValueText"
                               Grid.Column="2"
                               Width="50"
                               VerticalAlignment="Center"
                               Text="1.00x" />
                </Grid>

                <TextBlock Margin="0,6,0,8"
                           Foreground="#64748B"
                           TextWrapping="Wrap"
                           Text="默认自动适配系统缩放。只有框选位置仍有偏移时，才需要微调这个值。" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="选读" />
                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="Alt +" />
                        <ComboBox x:Name="SelectionReadComboBox"
                                  Width="80"
                                  Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="剪贴板朗读" />
                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center"
                                   Text="Alt +" />
                        <ComboBox x:Name="ClipboardReadComboBox"
                                  Width="80"
                                  Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="暂停/继续" />
                    <ComboBox x:Name="PlayPauseComboBox"
                              Grid.Column="1"
                              Width="96"
                              Margin="16,0,0,0" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="后退 5s" />
                    <ComboBox x:Name="PreviousComboBox"
                              Grid.Column="1"
                              Width="96"
                              Margin="16,0,0,0" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="前进 5s" />
                    <ComboBox x:Name="NextComboBox"
                              Grid.Column="1"
                              Width="96"
                              Margin="16,0,0,0" />
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock VerticalAlignment="Center"
                               Text="停止" />
                    <ComboBox x:Name="StopComboBox"
                              Grid.Column="1"
                              Width="96"
                              Margin="16,0,0,0" />
                </Grid>

                <TextBlock Margin="0,16,0,0"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           Text="当前版本先支持 Alt + 字母或方向键。保存后立即生效，并会在下次启动时保留。" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="80"
                    Height="30"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    Content="取消" />
            <Button Width="80"
                    Height="30"
                    Click="SaveButton_Click"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
